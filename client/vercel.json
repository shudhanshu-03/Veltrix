{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "api/*.cjs",
      "use": "@vercel/node"
    },
    {
      "src": "api/games/*.cjs",
      "use": "@vercel/node"
    },
    {
      "src": "api/steam/*.cjs",
      "use": "@vercel/node"
    },
    {
      "src": "api/steam/*/*.cjs",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/games", "dest": "/api/games.cjs" },
    { "src": "/api/games/([^/]+)", "dest": "/api/games/[id].cjs?id=$1" },
    { "src": "/api/genres", "dest": "/api/genres.cjs" },
    { "src": "/api/search", "dest": "/api/search.cjs" },
    { "src": "/api/stats", "dest": "/api/stats.cjs" },
    { "src": "/api/steam/catalog", "dest": "/api/steam/catalog.cjs" },
    { "src": "/api/steam/featured", "dest": "/api/steam/featured.cjs" },
    { "src": "/api/steam/game/([^/]+)", "dest": "/api/steam/game/[gameId].cjs?gameId=$1" },
    { "src": "/api/steam/news/([^/]+)", "dest": "/api/steam/news/[gameId].cjs?gameId=$1" },
    { "src": "/api/steam/price/([^/]+)", "dest": "/api/steam/price/[gameId].cjs?gameId=$1" },
    { "src": "/api/steam/reviews/([^/]+)", "dest": "/api/steam/reviews/[gameId].cjs?gameId=$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
