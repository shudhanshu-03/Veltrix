{
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/genres",                "destination": "/api/genres" },
    { "source": "/api/games/:id",             "destination": "/api/games/[id]" },
    { "source": "/api/games",                 "destination": "/api/games" },
    { "source": "/api/search",                "destination": "/api/search" },
    { "source": "/api/stats",                 "destination": "/api/stats" },
    { "source": "/api/steam/game/:gameId",    "destination": "/api/steam/game/[gameId]" },
    { "source": "/api/steam/catalog",         "destination": "/api/steam/catalog" },
    { "source": "/api/steam/featured",        "destination": "/api/steam/featured" },
    { "source": "/api/steam/news/:gameId",    "destination": "/api/steam/news/[gameId]" },
    { "source": "/api/steam/reviews/:gameId", "destination": "/api/steam/reviews/[gameId]" },
    { "source": "/api/steam/price/:gameId",   "destination": "/api/steam/price/[gameId]" },
    { "source": "/(.*)",                      "destination": "/index.html" }
  ]
}
