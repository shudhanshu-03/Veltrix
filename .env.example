# Gaming Hub — Environment Config
# Copy this to .env and fill in values

# Port for the Express server (local dev only — not used on Vercel)
PORT=3000

# Supabase credentials (required for API serverless functions)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_publishable_key_here

# Steam Web API Key (OPTIONAL — improves rate limits for some endpoints)
# Get yours free at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
