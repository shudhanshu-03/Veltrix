# Veltrix - Environment Config
# Copy this to .env and fill in values

# Port for the Express server
PORT=3000

# JWT Secret for Auth (use a strong random string in production)
JWT_SECRET=veltrix-sqlite-dev-secret

# Steam Web API Key (OPTIONAL - improves rate limits for some endpoints)
# Get yours free at: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
